[28.637358, "o", "  \u001b[2mSame logic, correct code. Governance is silent when code is right.\u001b[0m\r\n\r\n\u001b[2m─── /data/data/com.termux/files/home/.naab/language/demo/scene7_fixed.naab ───\u001b[0m\r\n\u001b[1;33m\r\n"]
[28.648616, "o", "// Scene 7: All issues fixed — governance passes clean\r\nuse env\r\n\r\nfn validate_user_input(input) {\r\n    let cleaned = string(input)\r\n    if cleaned.contains(\"DROP\") || cleaned.contains(\"--\") || cleaned.contains(\";\") {\r\n        return \"invalid\"\r\n    }\r\n    if cleaned.length() > 100 {\r\n        return \"too_long\"\r\n    }\r\n    return cleaned\r\n}\r\n\r\nfn sanitize_for_shell(input) {\r\n    let safe = string(input)\r\n    safe = safe.replace(\"\\\"\", \"\")\r\n    safe = safe.replace(\"'\", \"\")\r\n    safe = safe.replace(\";\", \"\")\r\n    safe = safe.replace(\"|\", \"\")\r\n    safe = safe.replace(\"&\", \"\")\r\n    safe = safe.replace(\"$\", \"\")\r\n    safe = safe.replace(\"`\", \"\")\r\n    return safe\r\n}\r\n\r\nfn fetch_user_data(user_id) {\r\n    try {\r\n        let data = <<python\r\nimport json\r\njson.loads('{\"name\": \"Alice\", \"id\": 42}')\r\n>>\r\n        return data\r\n    } catch (e) {\r\n        print(\"Failed to fetch user \" + string(user_id) + \": \" + string(e))\r\n        return {\"error\": string(e)}\r\n    }\r\n}\r\n\r\nmain {\r\n    // Fix 1: Use .append() not .push()\r\n    let result = <<python\r\ndata = [1, 2, 3]\r\ndata.append(4)\r\ndata.append(5)\r\nlen(data)\r\n>>\r\n    print(\"Python result: \" + string(result))\r\n\r\n    // Fix 2: Use real package (json is in known modules)\r\n    let parsed = <<python\r\nimport json\r\njson.dumps({\"status\": \"ok\", \"count\": 5})\r\n>>\r\n    print(\"JSON: \" + string(parsed))\r\n\r\n    // Fix 3: Real validation logic (not a stub)\r\n    let safe = validate_user_input(\"hello world\")\r\n    print(\"Validated: \" + string(safe))\r\n\r\n    // Fix 4: Use environment variable, not hardcoded\r\n    let api_key = env.get(\"API_KEY\")\r\n    print(\"API key from env: \" + string(api_key != null))\r\n\r\n    // Fix 5: Proper error handling\r\n    let user = fetch_user_data(42)\r\n    print(\"User: \" + string(user))\r\n\r\n    // Fix 6: Sanitize before shell\r\n    let user_input = env.get(\"USER_QUERY\")\r\n    let clean_input = sanitize_for_shell(user_input)\r\n    let search = <<shell[clean_input]\r\necho \"Searching for: $clean_input\"\r\n>>\r\n    print(\"Search: \" + string(search))\r\n\r\n    print(\"\")\r\n    print(\"All 6 governance checks passed!\")\r\n}\r\n"]
[28.649795, "o", "\u001b[0m\r\n"]
