[29.786902, "o", "\r\n\u001b[0;32m\u001b[1m  ✓ All governance checks passed\u001b[0m\r\n"]
[31.79949, "o", "\r\n\u001b[0;36m\u001b[1m══════════════════════════════════════════════════════\u001b[0m\r\n\u001b[0;36m\u001b[1m  Summary\u001b[0m\r\n\u001b[0;36m\u001b[1m══════════════════════════════════════════════════════\u001b[0m\r\n\r\n  \u001b[0;32m✓\u001b[0m Cross-language API hallucination    \u001b[0;31m→ caught\u001b[0m\r\n  \u001b[0;32m✓\u001b[0m Fake Python package import          \u001b[0;31m→ caught\u001b[0m\r\n  \u001b[0;32m✓\u001b[0m Stub function (return true)         \u001b[0;31m→ caught\u001b[0m\r\n  \u001b[0;32m✓\u001b[0m Hardcoded API key                   \u001b[0;31m→ caught\u001b[0m\r\n  \u001b[0;32m✓\u001b[0m Empty error handler                 \u001b[0;31m→ caught\u001b[0m\r\n  \u001b[0;32m✓\u001b[0m Unsanitized data in shell           \u001b[0;31m→ caught\u001b[0m\r\n  \u001b[0;32m✓\u001b[0m Fixed version                       \u001b[0;32m→ passed\u001b[0m\r\n\r\n  \u001b[1mOne govern.json. Zero bad code gets through.\u001b[0m\r\n\r\n  \u001b[2mLearn more: https://github.com/b-macker/NAAb\u001b[0m\r\n\r\n"]
