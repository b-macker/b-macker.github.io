[19.424538, "o", "\u001b[0;36m\u001b[1m══════════════════════════════════════════════════════\u001b[0m\r\n\r\n"]
[20.444863, "o", "  \u001b[2mAI generates try/catch that silently ignores failures.\u001b[0m\r\n  \u001b[2mNAAb detects empty error handlers and dummy conditionals.\u001b[0m\r\n\r\n\u001b[2m─── /data/data/com.termux/files/home/.naab/language/demo/scene5_incomplete.naab ───\u001b[0m\r\n\u001b[1;33m\r\n"]
[20.45566, "o", "// Scene 5: AI swallowed errors with empty catch blocks\r\nfn fetch_user_data(user_id) {\r\n    try {\r\n        let data = <<python\r\nimport json\r\njson.loads('{\"name\": \"Alice\", \"id\": 42}')\r\n>>\r\n        return data\r\n    } catch (e) {\r\n    }\r\n    return null\r\n}\r\n\r\nmain {\r\n    let user = fetch_user_data(42)\r\n    print(\"User: \" + string(user))\r\n}\r\n"]
