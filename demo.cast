[0.027771, "o", "\u001b[1m\u001b[0;36m│   NAAb Governance Demo                                   │\u001b[0m\r\n\u001b[1m\u001b[0;36m│   Catching AI-generated code mistakes at runtime          │\u001b[0m\r\n\u001b[1m\u001b[0;36m│                                                          │\u001b[0m\r\n\u001b[1m\u001b[0;36m│   6 mistakes. 1 govern.json. 0 bad code gets through.    │\u001b[0m\r\n\u001b[1m\u001b[0;36m│                                                          │\u001b[0m\r\n\u001b[1m\u001b[0;36m└──────────────────────────────────────────────────────────┘\u001b[0m\r\n\r\n"]
[3.040235, "o", "\r\n\u001b[0;36m\u001b[1m══════════════════════════════════════════════════════\u001b[0m\r\n\u001b[0;36m\u001b[1m  Scene 1: AI uses JavaScript .push() in Python\u001b[0m\r\n\u001b[0;36m\u001b[1m══════════════════════════════════════════════════════\u001b[0m\r\n\r\n"]
[4.055858, "o", "  \u001b[2mAI models frequently confuse APIs across languages.\u001b[0m\r\n  \u001b[2mNAAb knows 86+ cross-language confusion patterns.\u001b[0m\r\n\r\n\u001b[2m─── /data/data/com.termux/files/home/.naab/language/demo/scene1_hallucination.naab ───\u001b[0m\r\n\u001b[1;33m\r\n"]
