[24.542057, "o", "  \u001b[2mAI reads from environment and passes directly to shell.\u001b[0m\r\n  \u001b[2mNAAb tracks data flow: source -> variable -> sink.\u001b[0m\r\n\r\n\u001b[2m─── /data/data/com.termux/files/home/.naab/language/demo/scene6_taint.naab ───\u001b[0m\r\n\u001b[1;33m\r\n"]
[24.555233, "o", "// Scene 6: AI passed user input directly to a shell command\r\nuse env\r\n\r\nmain {\r\n    let user_input = env.get(\"USER_QUERY\")\r\n    let result = <<shell[user_input]\r\necho \"Searching for: $user_input\"\r\n>>\r\n    print(string(result))\r\n}\r\n"]
